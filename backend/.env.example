NODE_ENV=development
PORT=5000

# PostgreSQL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/moodmix

# ML microservice (Phase 3 — HuggingFace via FastAPI)
ML_SERVICE_URL=http://localhost:8000
# Set to false to force rule-based stub only
USE_ML_SERVICE=true

# Frontend origin (CORS in production)
FRONTEND_URL=http://127.0.0.1:5173

# Session cookie signing (required for login)
SESSION_SECRET=change-me-in-production
